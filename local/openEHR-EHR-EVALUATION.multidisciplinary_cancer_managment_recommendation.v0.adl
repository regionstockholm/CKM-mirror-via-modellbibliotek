definition
	EVALUATION[at0000] matches {    -- Multidisciplinär handläggning vid cancer
		data matches {
			ITEM_TREE[at0001] matches {    -- Item tree
				items cardinality matches {0..*; unordered} matches {
					CLUSTER[at0002] occurrences matches {0..1} matches {    -- Rekommenderad behandlingsstrategi
						items cardinality matches {1..*; unordered} matches {
							ELEMENT[at0006] occurrences matches {0..1} matches {    -- Intention
								value matches {
									DV_TEXT matches {*}
								}
							}
							CLUSTER[at0007] occurrences matches {0..1} matches {    -- Huvudbehandling
								items cardinality matches {1..*; unordered} matches {
									ELEMENT[at0008] occurrences matches {0..1} matches {    -- Typ av behandling
										value matches {
											DV_TEXT matches {*}
										}
									}
									ELEMENT[at0009] occurrences matches {0..1} matches {    -- Regim
										value matches {
											DV_TEXT matches {*}
										}
									}
									ELEMENT[at0010] occurrences matches {0..1} matches {    -- Antal kurer
										value matches {
											DV_COUNT matches {*}
										}
									}
									ELEMENT[at0011] occurrences matches {0..1} matches {    -- Fraktionsdos
										value matches {
											C_DV_QUANTITY <
												property = <[openehr::508]>
												list = <
													["1"] = <
														units = <"Gy">
													>
												>
											>
										}
									}
									ELEMENT[at0012] occurrences matches {0..1} matches {    -- Totaldos
										value matches {
											C_DV_QUANTITY <
												property = <[openehr::508]>
												list = <
													["1"] = <
														units = <"Gy">
													>
												>
											>
										}
									}
									ELEMENT[at0013] occurrences matches {0..1} matches {    -- Form av kemoradioterapi
										value matches {
											DV_TEXT matches {*}
										}
									}
									ELEMENT[at0014] occurrences matches {0..1} matches {    -- Kommentar
										value matches {
											DV_TEXT matches {*}
										}
									}
									allow_archetype CLUSTER[at0015] occurrences matches {0..*} matches {    -- Övrig information
										include
											archetype_id/value matches {/.*/}
									}
								}
							}
							CLUSTER[at0016] occurrences matches {0..1} matches {    -- Tilläggsbehandling
								items cardinality matches {1..*; unordered} matches {
									ELEMENT[at0025] occurrences matches {0..1} matches {    -- Relation till huvudbehandling
										value matches {
											DV_TEXT matches {*}
										}
									}
									ELEMENT[at0017] occurrences matches {0..1} matches {    -- Typ av behandling
										value matches {
											DV_TEXT matches {*}
										}
									}
									ELEMENT[at0018] occurrences matches {0..1} matches {    -- Regim
										value matches {
											DV_TEXT matches {*}
										}
									}
									ELEMENT[at0019] occurrences matches {0..1} matches {    -- Antal kurer
										value matches {
											DV_COUNT matches {*}
										}
									}
									ELEMENT[at0020] occurrences matches {0..1} matches {    -- Fraktionsdos
										value matches {
											C_DV_QUANTITY <
												property = <[openehr::508]>
												list = <
													["1"] = <
														units = <"Gy">
													>
												>
											>
										}
									}
									ELEMENT[at0021] occurrences matches {0..1} matches {    -- Totaldos
										value matches {
											C_DV_QUANTITY <
												property = <[openehr::508]>
												list = <
													["1"] = <
														units = <"Gy">
													>
												>
											>
										}
									}
									ELEMENT[at0022] occurrences matches {0..1} matches {    -- Form av kemoradioterapi
										value matches {
											DV_TEXT matches {*}
										}
									}
									ELEMENT[at0023] occurrences matches {0..1} matches {    -- Kommentar
										value matches {
											DV_TEXT matches {*}
										}
									}
									allow_archetype CLUSTER[at0024] occurrences matches {0..*} matches {    -- Övrig information
										include
											archetype_id/value matches {/.*/}
									}
								}
							}
						}
					}
					ELEMENT[at0004] occurrences matches {0..1} matches {    -- Vidare utredning
						value matches {
							DV_TEXT matches {*}
						}
					}
					ELEMENT[at0005] occurrences matches {0..1} matches {    -- Uppföljning
