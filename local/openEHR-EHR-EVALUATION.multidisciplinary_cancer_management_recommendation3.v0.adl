				["at0047"] = <
					text = <"Additional details">
					description = <"">
				>
				["at0049"] = <
					text = <"Additional treatment">
					description = <"Therapies given in addition to the main treatment, aimed at improving the effects of the main treatment. Additional treatment can be given before, after, or both before and after the main treatment.">
