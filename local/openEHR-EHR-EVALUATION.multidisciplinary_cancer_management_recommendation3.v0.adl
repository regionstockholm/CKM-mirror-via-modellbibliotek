					description = <"Total amount of radiation recommended for the entire treatment course.">
				>
				["at0033"] = <
					text = <"Chemoradiotherapy form">
					description = <"The timing of chemotherapy relative to radiotherapy within the recommended treatment regimen.">
				>
				["at0038"] = <
					text = <"Regimen">
					description = <"Specified oncological treatment regimen.">
				>
				["at0042"] = <
					text = <"Tumor-targeted treatment">
					description = <"
Treatment that is directly aimed at slowing, reducing or eliminating the growth of a cancerous tumor.">
				>
				["at0043"] = <
					text = <"Comment">
					description = <"">
				>
				["at0044"] = <
					text = <"Non-tumor-directed treatment">
					description = <"Therapeutic approaches that do not directly aim to kill cancer cells, shrink tumors, or eliminate metastases.">
				>
				["at0045"] = <
					text = <"Type of treatment">
					description = <"Type of non-tumor-directed treatment.">
				>
