definition
	EVALUATION[at0000] matches {    -- multidisciplinary_cancer_management_recommendation3
		data matches {
			ITEM_TREE[at0001] matches {    -- Item tree
				items cardinality matches {0..*; unordered} matches {
					CLUSTER[at0002] occurrences matches {0..1} matches {    -- Recommended treatment strategy
						items cardinality matches {0..*; unordered} matches {
							CLUSTER[at0042] occurrences matches {0..1} matches {    -- Tumor-targeted treatment
								items cardinality matches {1..*; unordered} matches {
									ELEMENT[at0010] occurrences matches {0..1} matches {    -- Intent
										value matches {
											DV_TEXT matches {*}
										}
									}
									CLUSTER[at0007] occurrences matches {0..*} matches {    -- Main treatament
										items cardinality matches {0..*; unordered} matches {
											ELEMENT[at0011] occurrences matches {0..1} matches {    -- Type of treatment
												value matches {
													DV_TEXT matches {*}
												}
											}
											ELEMENT[at0038] occurrences matches {0..1} matches {    -- Regimen
												value matches {
													DV_TEXT matches {*}
												}
											}
											ELEMENT[at0031] occurrences matches {0..1} matches {    -- Number of cycles
												value matches {
													DV_COUNT matches {*}
												}
											}
											ELEMENT[at0030] occurrences matches {0..1} matches {    -- Fractionated dose
												value matches {
													DV_QUANTITY matches {*}
												}
											}
											ELEMENT[at0032] occurrences matches {0..1} matches {    -- Total dose
												value matches {
													DV_QUANTITY matches {*}
												}
											}
											ELEMENT[at0033] occurrences matches {0..1} matches {    -- Chemoradiotherapy form
												value matches {
													DV_TEXT matches {*}
												}
											}
											ELEMENT[at0043] occurrences matches {0..1} matches {    -- Comment
												value matches {
													DV_TEXT matches {*}
												}
											}
											allow_archetype CLUSTER[at0014] occurrences matches {0..*} matches {    -- Additional details
												include
													archetype_id/value matches {/.*/}
											}
										}
									}
									CLUSTER[at0049] occurrences matches {0..1} matches {    -- Additional treatment
										items cardinality matches {0..*; unordered} matches {
											ELEMENT[at0058] occurrences matches {0..1} matches {    -- Relation to main tretament
												value matches {
													DV_TEXT matches {*}
												}
											}
											ELEMENT[at0051] occurrences matches {0..1} matches {    -- Type of treatment
												value matches {
													DV_TEXT matches {*}
												}
											}
											ELEMENT[at0052] occurrences matches {0..1} matches {    -- Regimen
												value matches {
													DV_TEXT matches {*}
												}
											}
											ELEMENT[at0054] occurrences matches {0..1} matches {    -- Number of cycles
												value matches {
													DV_COUNT matches {*}
												}
											}
											ELEMENT[at0055] occurrences matches {0..1} matches {    -- Fractionated dose
												value matches {
													DV_QUANTITY matches {*}
												}
											}
											ELEMENT[at0056] occurrences matches {0..1} matches {    -- Total dose
												value matches {
													DV_QUANTITY matches {*}
												}
											}
											ELEMENT[at0057] occurrences matches {0..1} matches {    -- Chemoradiotherapy form
												value matches {
													DV_TEXT matches {*}
												}
											}
											ELEMENT[at0060] occurrences matches {0..1} matches {    -- Comment
												value matches {
													DV_TEXT matches {*}
												}
											}
											allow_archetype CLUSTER[at0059] occurrences matches {0..*} matches {    -- Additional details
												include
													archetype_id/value matches {/.*/}
											}
										}
									}
								}
							}
							CLUSTER[at0044] occurrences matches {0..1} matches {    -- Non-tumor-directed treatment
								items cardinality matches {1..*; unordered} matches {
									ELEMENT[at0045] occurrences matches {0..1} matches {    -- Type of treatment
										value matches {
											DV_TEXT matches {*}
										}
									}
									ELEMENT[at0046] occurrences matches {0..1} matches {    -- Comment
										value matches {
											DV_TEXT matches {*}
										}
									}
									allow_archetype CLUSTER[at0047] occurrences matches {0..*} matches {    -- Additional details
										include
											archetype_id/value matches {/.*/}
									}
								}
							}
							ELEMENT[at0005] occurrences matches {0..1} matches {    -- Patient eligible for study screening
								value matches {
