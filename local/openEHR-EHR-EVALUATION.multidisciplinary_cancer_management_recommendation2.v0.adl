definition
	EVALUATION[at0000] matches {    -- multidisciplinary_cancer_management_recommendation2
		data matches {
			ITEM_TREE[at0001] matches {    -- Item tree
				items cardinality matches {0..*; unordered} matches {
					CLUSTER[at0002] occurrences matches {0..1} matches {    -- Recommended treatment strategy
						items cardinality matches {0..*; unordered} matches {
							CLUSTER[at0042] occurrences matches {0..*} matches {    -- CLUSTER
								items cardinality matches {1..*; unordered} matches {
									ELEMENT[at0045] occurrences matches {0..*} matches {    -- DV_TEXT
										value matches {
											DV_TEXT matches {*}
										}
									}
									ELEMENT[at0046] occurrences matches {0..1} matches {    -- DV_TEXT
										value matches {
											DV_TEXT matches {*}
										}
									}
									ELEMENT[at0047] occurrences matches {0..1} matches {    -- DV_TEXT
										value matches {
											DV_TEXT matches {*}
										}
									}
									ELEMENT[at0048] occurrences matches {0..1} matches {    -- DV_COUNT
										value matches {
											DV_COUNT matches {*}
										}
									}
									allow_archetype CLUSTER[at0049] occurrences matches {0..*} matches {    -- CLUSTER_SLOT
										include
											archetype_id/value matches {/.*/}
									}
								}
							}
							CLUSTER[at0043] occurrences matches {0..1} matches {    -- CLUSTER
								items cardinality matches {1..*; unordered} matches {
									ELEMENT[at0044] occurrences matches {0..1} matches {    -- DV_TEXT
										value matches {
											DV_TEXT matches {*}
										}
									}
								}
							}
						}
					}
					CLUSTER[at0003] occurrences matches {0..1} matches {    -- Futher investigation
						items cardinality matches {0..*; unordered} matches {
							ELEMENT[at0024] occurrences matches {0..1} matches {    -- Description futher investigation
								value matches {
									DV_TEXT matches {*}
								}
							}
						}
					}
					ELEMENT[at0027] occurrences matches {0..1} matches {    -- Follow up
						value matches {
							DV_TEXT matches {*}
						}
					}
				}
			}
		}
		protocol matches {
			ITEM_TREE[at0026] matches {*}    -- Item tree
		}
	}

