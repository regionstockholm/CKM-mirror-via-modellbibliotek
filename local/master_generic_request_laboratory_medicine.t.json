      "sv" : {
        "at0153.1" : {
          "@type" : "ARCHETYPE_TERM",
          "code" : "at0153.1",
          "text" : "Beställningsdetaljer",
          "description" : "*Additional details and instructions about how the services are to be delivered. (en)",
          "comment" : "*Coding of the order detail with a terminology is preferred, where possible. This data element allows multiple occurrences.  (en)"
        },
        "at0148.1" : {
          "@type" : "ARCHETYPE_TERM",
          "code" : "at0148.1",
          "text" : "Laboratoriedisciplin",
          "description" : "Kategori på typ av efterfrågad tjänst",
          "comment" : "Kodning av \"Typ av tjänst\" är att föredra, om möjligt. Om 'Namn på tjänst' är kodat är det möjligt för detta dataelement att härledas från koden. Exempelvis: biokemi eller mikrobiologi laboratorium, ultraljud eller datatomografi."
        },
        "at0076.1" : {
          "@type" : "ARCHETYPE_TERM",
          "code" : "at0076.1",
          "text" : "Kompletterande information",
          "description" : "Kompletterande information kommer efter begäran.",
          "comment" : "Ange som SANT om ytterligare information har identifierats och kommer att vidarebefordras när den är tillgänglig. Till exempel: väntande testresultat."
        },
        "at0000.1" : {
          "@type" : "ARCHETYPE_TERM",
          "code" : "at0000.1",
          "text" : "Generiskt beställningsunderlag laboratoriemedicin",
          "description" : "Förfrågan om en hälso- och sjukvårdsrelaterad tjänst eller aktivitet som behöver genomföras av en kliniker, organisation eller myndighet. \r\n"
        },
        "at0010.1" : {
          "@type" : "ARCHETYPE_TERM",
          "code" : "at0010.1",
          "text" : "Remiss-ID",
          "description" : "Den lokala identifieraren som tilldelats av det begärande kliniska systemet.",
          "comment" : "Vanligtvis motsvarande HL7 Placer Order Identifier."
        },
        "at0062.1" : {
          "@type" : "ARCHETYPE_TERM",
          "code" : "at0062.1",
          "text" : "Frågeställning",
          "description" : "En kort mening om varför tjänsten efterfrågas.",
          "comment" : "Kodning av detta dataelement är önskvärt, om möjligt. \r\nDetta dataelement tillåter flera värden om så behövs och gör det möjligt för användaren att ge flera svar. Till exempel: \"hantera diabeteskomplikationer\"."
        },
        "at0152.1" : {
          "@type" : "ARCHETYPE_TERM",
          "code" : "at0152.1",
          "text" : "Indikation",
          "description" : "Den kliniska anledningen till den efterfrågade tjänsten.",
          "comment" : "Kodning av den kliniska indikationen med en terminologi är att föredra, där det är möjligt. Detta dataelement tillåter flera förekomster. Till exempel: 'Angina' eller 'Type 1 Diabetes mellitus'."
        }
      },
